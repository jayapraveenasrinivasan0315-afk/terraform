# Backend Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control

# Database Configuration
# For local development: postgresql://postgres:postgres@localhost:5432/mytable
# For Cloud SQL: postgresql://myapp_user:PASSWORD@/myapp?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mytable

# Server Configuration
PORT=8080
HOST=0.0.0.0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Optional: API Settings
API_TITLE=MyApp API
API_VERSION=1.0.0
