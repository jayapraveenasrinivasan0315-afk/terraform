# Backend Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env to version control

# Database Configuration
# For local development (Cloud SQL private IP via VPC):
#   postgresql+psycopg2://myapp_user:PASSWORD@10.198.0.3:5432/myapp
# For local localhost: postgresql+psycopg2://postgres:postgres@localhost:5432/myapp
DATABASE_URL=postgresql+psycopg2://myapp_user:YOUR_PASSWORD_HERE@10.198.0.3:5432/myapp
# Server Configuration
PORT=8080
HOST=0.0.0.0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Optional: API Settings
API_TITLE=MyApp API
API_VERSION=1.0.0
